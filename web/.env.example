NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The runtime falls back to browser localStorage when Supabase variables are empty.
# On Vercel, set SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY so /api/snapshot can
# store only public/statistical data. Never add private question text, generated
# prompts, raw GPT JSON, statement text, or personal reading feedback to Supabase.
